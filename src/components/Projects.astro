---
const featuredProjects = [
  {
    name: 'Skillpath',
    description:
      'Plataforma de aprendizaje y onboarding con landing publica, panel admin, roadmaps generados con IA, manejo de habilidades, quizzes y carga de PDFs.',
    stack: ['Next.js', 'React', 'TypeScript', 'Convex', 'Clerk', 'Groq'],
    href: 'https://github.com/deltahbc2/Skillpath',
    accent: 'from-cyan-500/25 via-slate-900 to-slate-950',
    badge: 'AI + onboarding',
    initials: 'SP',
    spanClass: 'md:col-span-2',
  },
  {
    name: 'Dominoes',
    description:
      'Ecommerce moderno con autenticacion, checkout, pagos reales con Mercado Pago, panel de administracion y actualizaciones en tiempo real.',
    stack: ['Next.js', 'TypeScript', 'Convex', 'Clerk', 'Mercado Pago'],
    href: 'https://github.com/CesarOliva/Dominoes',
    accent: 'from-amber-500/25 via-slate-900 to-slate-950',
    badge: 'Ecommerce',
    initials: 'DO',
    spanClass: 'md:col-span-1',
  },
  {
    name: 'SIGAU',
    description:
      'Sistema academico con autenticacion por rol, paneles para alumno, docente y administrador, gestion de materias y reportes.',
    stack: ['Next.js', 'React', 'TypeScript', 'Express', 'MySQL'],
    href: 'https://github.com/CesarOliva/SIGAU',
    accent: 'from-violet-500/25 via-slate-900 to-slate-950',
    badge: 'Sistema de negocio',
    initials: 'SG',
    spanClass: 'md:col-span-1',
  },
  {
    name: 'Regionerate',
    description:
      'Plataforma con mapa interactivo para explorar especies nativas de Nuevo Leon y apoyar decisiones de reforestacion con datos.',
    stack: ['Next.js', 'React', 'TypeScript', 'Convex', 'Leaflet'],
    href: 'https://github.com/deltahbc2/regionerate',
    accent: 'from-emerald-500/25 via-slate-900 to-slate-950',
    badge: 'Impacto + mapa',
    initials: 'RE',
    spanClass: 'md:col-span-2',
  },
];

const secondaryProjects = [
  {
    name: 'EMMO',
    description:
      'Diario emocional con calendario mensual, registro de mood, notas, canciones por dia y actividades personalizadas.',
    stack: ['TypeScript', 'Next.js', 'UI centrada en experiencia'],
    href: 'https://github.com/CesarOliva/Emmo',
    accent: 'from-pink-500/20 via-slate-900 to-slate-950',
    badge: 'Producto pulido',
    initials: 'EM',
  },
  {
    name: 'Rifas HC',
    description:
      'Aplicacion para administrar rifas con landing publica, panel admin, boletos, ganadores, sorteos y notificaciones por correo.',
    stack: ['React', 'TypeScript', 'Vite', 'Tailwind CSS', 'PHP'],
    href: 'https://github.com/CesarOliva/rifashc',
    accent: 'from-sky-500/20 via-slate-900 to-slate-950',
    badge: 'Full-stack',
    initials: 'RH',
  },
  {
    name: 'Carbon Tracker',
    description:
      'Aplicacion de escritorio en Python para cargar Excel, procesar emisiones de CO2 y generar resultados desde una interfaz grafica.',
    stack: ['Python', 'Pandas', 'CustomTkinter', 'Matplotlib'],
    href: 'https://github.com/CesarOliva/Carbon-Tracker',
    accent: 'from-lime-500/20 via-slate-900 to-slate-950',
    badge: 'Python desktop',
    initials: 'CT',
  },
];
---

<section id="projects" class="py-24 px-6">
    <div class="max-w-300 mx-auto px-2 md:px-12">
        <div class="flex items-center gap-4 mb-16">
            <h2 class="text-3xl font-bold font-mono">Proyectos Destacados</h2>
            <div class="h-px grow bg-neutral-800"></div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {featuredProjects.map((project) => (
                <a
                    href={project.href}
                    target="_blank"
                    rel="noreferrer"
                    class={`rounded-2xl border border-gray-800/50 hover:border-gray-700 transition-colors overflow-hidden group ${project.spanClass}`}
                >
                    <div class={`h-64 bg-linear-to-br ${project.accent} relative overflow-hidden`}>
                        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.15),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.08),transparent_30%)]"></div>
                        
                        <div class="absolute inset-0 flex items-end justify-between p-6">
                            <div>
                                <div class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-mono text-gray-200">
                                    {project.badge}
                                </div>
                                <div class="mt-4 text-5xl font-black tracking-tight text-white/90">
                                    {project.initials}
                                </div>
                            </div>
                            <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-right backdrop-blur-sm">
                                <p class="text-xs uppercase tracking-[0.2em] text-gray-400">Repo</p>
                                <p class="mt-1 text-sm text-gray-200">{project.name}</p>
                            </div>
                        </div>
                    </div>

                    <div class="p-8">
                        <h3 class="font-semibold text-2xl mb-2">{project.name}</h3>
                        <p class="text-md text-gray-400">{project.description}</p>

                        <div class="flex flex-wrap gap-1 mt-4">
                            {project.stack.map((tech) => (
                            <span class="px-3 py-1 bg-neutral-800 border border-gray-800 rounded-md text-sm font-mono text-gray-400">
                                {tech}
                            </span>
                            ))}
                        </div>
                    </div>
                </a>
            ))}
        </div>

        <div class="flex items-center gap-4 mt-20 mb-10">
            <h3 class="text-2xl font-bold font-mono">Otros proyectos</h3>
            <div class="h-px grow bg-neutral-800"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            {secondaryProjects.map((project) => (
                <a
                    href={project.href}
                    target="_blank"
                    rel="noreferrer"
                    class="rounded-2xl border border-gray-800/50 hover:border-gray-700 transition-colors overflow-hidden group"
                >
                    <div class={`h-52 bg-linear-to-br ${project.accent} relative overflow-hidden`}>

                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.15),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.08),transparent_30%)]"></div>
                        <div class="absolute inset-0 p-6 flex flex-col justify-between">
                            <span class="inline-flex w-fit items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-mono text-gray-200">
                                {project.badge}
                            </span>
                            <div class="text-4xl font-black tracking-tight text-white/90">{project.initials}</div>
                        </div>
                    </div>

                    <div class="p-6">
                        <h3 class="font-semibold text-xl mb-2">{project.name}</h3>
                        <p class="text-sm text-gray-400">{project.description}</p>

                        <div class="flex flex-wrap gap-1 mt-4">
                            {project.stack.map((tech) => (
                                <span class="px-2.5 py-1 bg-neutral-800 border border-gray-800 rounded-md text-xs font-mono text-gray-400">
                                    {tech}
                                </span>
                            ))}
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>