---

const icons = {
    "Next.js": "fa-brands fa-react text-white",
    "React": "fa-brands fa-react text-cyan-400",
    "Typescript": "fa-brands fa-square-js text-blue-400",
    "Convex": "fa-solid fa-database text-[#f3b01c]",
    "Mercado Pago": "fa-solid fa-credit-card text-[#00b5f6]",
    "Leaflet": "fa-solid fa-leaf text-green-500",
    "Java": "fa-brands fa-java text-white",
    "MySQL": "fa-solid fa-database text-[#00628c]",
    "Clerk": "fa-solid fa-user-lock text-[#7e7abd]"
};

type Technology = keyof typeof icons;

type Project = {
    title: string;
    slug: string;
    description: string;
    technologies: Technology[];
    link: string;
    image?: string;
    span: string;
};

const projectsContent: Record<'es' | 'en', Project[]> = {
    es: [
        {
            title: "Regionerate",
            slug: "Mapa interactivo",
            description: "Plataforma con mapa interactivo para explorar especies nativas de Nuevo León y apoyar decisiones de reforestación con datos.",
            technologies: ["React", "Typescript", "Convex", "Leaflet"],
            link: "https://github.com/deltahbc2/regionerate",
            image: "/Images/Projects/Regionerate.png",
            span: "md:col-span-5"
        },
        {
            title: "Dominoes",
            slug: "Ecommerce",
            description: "Ecommerce moderno con autenticación, checkout, pasarela de pagos, panel de administración y actualizaciones en tiempo real.",
            technologies: ["Next.js", "Typescript", "Convex", "Mercado Pago"],
            link: "https://github.com/CesarOliva/Dominoes",
            image: "/Images/Projects/Dominoes.png",
            span: "md:col-span-3"
        },
        {
            title: "Gestor Biblioteca",
            slug: "App de escritorio",
            description: "Aplicación de escritorio para gestionar una biblioteca, permitiendo el registro de libros, usuarios y préstamos.",
            technologies: ["Java", "MySQL"],
            link: "https://github.com/CesarOliva/GestorBiblioteca",
            image: "/Images/Projects/GestorBiblioteca.png",
            span: "md:col-span-3"
        },
        {
            title: "Skillpath",
            slug: "IA + onboarding",
            description: "Plataforma de aprendizaje y onboarding con landing pública, panel admin, roadmaps generados con IA, manejo de habilidades, quizzes y carga de PDFs.",
            technologies: ["Next.js", "Typescript", "Convex", "Clerk"],
            link: "https://github.com/deltahbc2/Skillpath",
            image: "/Images/Projects/Skillpath.png",
            span: "md:col-span-5"
        }
    ],

    en: [
        {
            title: "Regionerate",
            slug: "Interactive Map",
            description: "Platform with an interactive map to explore native species of Nuevo León and support reforestation decisions using data.",
            technologies: ["React", "Typescript", "Convex", "Leaflet"],
            link: "https://github.com/deltahbc2/regionerate",
            image: "/Images/Projects/Regionerate.png",
            span: "md:col-span-5"
        },
        {
            title: "Dominoes",
            slug: "E-commerce",
            description: "Modern e-commerce platform with authentication, checkout, payment gateway, admin dashboard, and real-time updates.",
            technologies: ["Next.js", "Typescript", "Convex", "Mercado Pago"],
            link: "https://github.com/CesarOliva/Dominoes",
            image: "/Images/Projects/Dominoes.png",
            span: "md:col-span-3"
        },
        {
            title: "Library Manager",
            slug: "Desktop App",
            description: "Desktop application for library management, including books, users, and loan tracking.",
            technologies: ["Java", "MySQL"],
            link: "https://github.com/CesarOliva/GestorBiblioteca",
            image: "/Images/Projects/GestorBiblioteca.png",
            span: "md:col-span-3"
        },
        {
            title: "Skillpath",
            slug: "AI + Onboarding",
            description: "Learning and onboarding platform with a public landing page, admin dashboard, AI-generated roadmaps, skill management, quizzes, and PDF uploads.",
            technologies: ["Next.js", "Typescript", "Convex", "Clerk"],
            link: "https://github.com/deltahbc2/Skillpath",
            image: "/Images/Projects/Skillpath.png",
            span: "md:col-span-5"
        }
    ]
};

const { lang = 'es' }: { lang?: 'es' | 'en' } = Astro.props.language ? { lang: Astro.props.language } : {};

const projects = projectsContent[lang];

---

<section id="projects" class="py-24 px-6">
    <div class="max-w-300 mx-auto px-2 md:px-12">
        <div class="flex items-center gap-4 mb-16">
            <h2 class="text-3xl font-bold font-mono">{lang === 'es' ? 'Proyectos Destacados' : 'Featured Projects'}</h2>
            <div class="h-px grow bg-neutral-800"></div>
        </div>

        <div class="grid md:grid-cols-8 gap-6">
            {projects.map((project: Project) => (
                <a
                    href={project.link}
                    target="_blank"
                    rel="noreferrer"
                    class={`rounded-2xl border border-[#cfb095]/10 hover:border-[#ab805a]/50 transition-colors overflow-hidden group ${project.span}`}
                >
                    <div class="h-64 bg-linear-to-br from-amber-500/25 via-slate-900 to-slate-950 relative overflow-hidden">
                        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,0.15),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(255,255,255,0.08),transparent_30%)]"></div>
                            
                        <div class="absolute inset-0 flex items-end justify-between p-6">
                            <div>
                                <div class="mt-4 text-2xl font-black tracking-tight text-white/90">
                                    {/* {project.slug} */}
                                </div>
                            </div>
                        </div>

                        <img src={project.image} alt={project.title} class="w-full h-full object-cover">
                    </div>

                    <div class="p-8">
                        <h3 class="font-semibold text-2xl mb-2 group-hover:text-[#ab805a]">{project.title}</h3>
                        <p class="text-md text-gray-400">{project.description}</p>

                        <div class="flex flex-wrap gap-2 mt-4">
                            {project.technologies.map((tech: Technology) => (
                                <span class="px-3 py-1 bg-neutral-800 border border-gray-800 rounded-md text-sm font-mono text-gray-400 flex items-center gap-2">
                                    <i class={icons[tech]}></i>{tech}
                                </span>
                            ))}
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>