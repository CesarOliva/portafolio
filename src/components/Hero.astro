---
import { ArrowRight, Download } from '@lucide/astro';
---

<section id="hero" class="relative min-h-screen max-w-300 mx-auto flex items-center justify-center overflow-hidden px-6">
    <div class="absolute inset-0 z-0">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#ab805a]/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-[#cfb095]/10 rounded-full blur-[120px]"></div>
    </div>
    
    <div class="relative z-10 max-w-4xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-dark-200 border border-dark-300 text-xs font-mono text-gray-400 mb-8">
            <span class="w-2 h-2 rounded-full bg-[#ab805a] animate-pulse"></span>
            Disponible para nuevas oportunidades
        </div>

        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">
            <span class="block text-gray-400 text-2xl md:text-3xl font-mono mb-4">Hola, soy</span>
            César Oliva
        </h1>

        <h2 class="text-3xl md:text-5xl font-bold mb-8 text-[#ab805a]">Frontend Developer</h2>
        <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-12 leading-relaxed">
            Desarrollador especializado en aplicaciones web modernas, con enfoque en arquitectura, rendimiento y experiencia de usuario.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="#projects" class="w-full sm:w-auto px-8 py-4 bg-white text-black font-semibold rounded-lg hover:bg-gray-100 transition-colors flex items-center justify-center gap-2">
                Ver proyectos
                <ArrowRight class="size-5"/>
            </a>
            <a href="#" class="w-full sm:w-auto px-8 py-4 glass-card text-white font-semibold rounded-lg hover:bg-dark-200 transition-colors flex items-center justify-center gap-2 border border-gray-800">
                Descargar CV
                <Download class="size-5"/>
            </a>
        </div>
    </div>
</section>