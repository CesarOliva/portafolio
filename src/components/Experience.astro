---

const experience = [
    {
        title: "Web Developer",
        place: "Freelancer",
        date: "Sep 2021 — Presente",
        description: [
            "Desarrollo de sitios web, landing pages, tiendas en línea y sistemas personalizados para negocios y emprendedores.",
            "Levantamiento de requerimientos, planificación de proyectos y comunicación directa con clientes.",
            "Despliegue, mantenimiento y optimización de aplicaciones web para mejorar rendimiento y experiencia de usuario."
        ],
        current: true
    },
    {
        title: "Web Developer & IT Support",
        place: "PSE Iluminación",
        date: "Dic 2023 — Mar 2025",
        description: [
            "Desarrollo y mantenimiento del sitio web corporativo y tienda en línea de la empresa.",
            "Creación de scripts y herramientas para automatizar tareas operativas y reducir trabajo manual.",
            "Configuración y soporte de sistemas utilizados en las operaciones diarias de la empresa."
        ],
    },
    {
        title: "WordPress Developer",
        place: "Primer En Publicidad",
        date: "Jul 2021 — Sep 2021",
        description: [
            "Desarrollo y personalización de sitios web utilizando WordPress.",
            "Implementación de mejoras de SEO técnico y optimización de contenido para motores de búsqueda.",
            "Adaptación de diseños responsivos para distintos dispositivos y navegadores.",
            "Colaboración con equipos de diseño y marketing en proyectos para clientes."
        ],
    }
]

---

<section id="projects" class="py-24 px-6 bg-neutral-900">
    <div class="max-w-300 mx-auto px-2 md:px-12">
        <div class="flex items-center gap-4 mb-16">
            <h2 class="text-3xl font-bold font-mono">Experiencia</h2>
            <div class="h-px grow bg-neutral-800"></div>
        </div>

        <div class="relative border-l border-gray-800 ml-4 md:ml-0 md:pl-8 space-y-12">
            {experience.map((exp) => (
                <div class="relative pl-8 md:pl-0">
                    <div class={`absolute w-3 h-3 bg-dark border-2 rounded-full -left-[42px] md:-left-[38px] top-2 ${exp.current ? 'animate-pulse border-[#cfb095]' : 'border-white'}`}></div>
                    <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-2 md:mb-0">
                        <h3 class="text-2xl font-bold text-white">{exp.title}</h3>
                        <span class="font-mono text-md text-[#cfb095] mt-1 md:mt-0">{exp.date}</span>
                    </div>
                    <h4 class="text-lg text-[#cfb095] mb-4">{exp.place}</h4>
                    <ul class="space-y-3 text-gray-400 text-md">
                        {exp.description.map((desc) => (
                            <li class="flex items-start gap-3">
                                <i class="text-[#cfb095] text-xs fa-solid fa-caret-right mt-1"></i>
                                <span>{desc}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>
    </div>
</section>